{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@hancr/database": ["libs/database/src/index.ts"],
      "@hancr/database/*": ["libs/database/src/lib/*"],
      "@hancr/redis": ["libs/redis/src/index.ts"],
      "@hancr/redis/*": ["libs/redis/src/lib/*"],
      "@hancr/order": ["libs/order/src/index.ts"],
      "@hancr/order/*": ["libs/order/src/lib/*"],
      "@hancr/geo": ["libs/geo/src/index.ts"],
      "@hancr/geo/*": ["libs/geo/src/lib/*"],
      "@hancr/notifications": ["libs/notifications/src/index.ts"],
      "@hancr/notifications/*": ["libs/notifications/src/lib/*"],
      "@hancr/sdui": ["libs/sdui/src/index.ts"],
      "@hancr/sdui/*": ["libs/sdui/src/lib/*"],
      "@hancr/wallet": ["libs/wallet/src/index.ts"],
      "@hancr/wallet/*": ["libs/wallet/src/lib/*"],
      "@hancr/sos": ["libs/sos/src/index.ts"],
      "@hancr/sos/*": ["libs/sos/src/lib/*"],
      "@hancr/observability": ["libs/observability/src/index.ts"],
      "@hancr/observability/*": ["libs/observability/src/lib/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
