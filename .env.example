# =============================================
# HANCR — نموذج متغيرات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم
# =============================================

# ===== قاعدة البيانات =====
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=hancr
DATABASE_USER=hancr
DATABASE_PASSWORD=hancr_dev_pass
DATABASE_URL=postgresql://hancr:hancr_dev_pass@localhost:5433/hancr
DATABASE_TEST_URL=postgresql://hancr:hancr_dev_pass@localhost:5433/hancr_test

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== المصادقة — 3 أسرار قوية منفصلة (≥32 محرفاً، لا تُكرّر بينها) =====
# ولّد كل واحد عبر: openssl rand -base64 48
# الخوادم ترفض الإقلاع إن كان أيّ سرّ مفقوداً أو أقصر من 32 محرفاً (fail-fast).
JWT_SECRET=CHANGE_ME_openssl_rand_-base64_48
JWT_DRIVER_SECRET=CHANGE_ME_DIFFERENT_FROM_RIDER
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_FROM_BOTH

# ===== الخرائط =====
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# ===== Firebase =====
FIREBASE_PROJECT_ID=hancr-app
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@hancr-app.iam.gserviceaccount.com

# ===== SMS (Twilio) =====
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ===== بوابات الدفع =====
HYPERPAY_ACCESS_TOKEN=your_hyperpay_token
MOYASAR_API_KEY=your_moyasar_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# ===== Sentry (المراقبة) =====
# DSN منفصل لكل project — أنشئ 5 projects في sentry.io
# (rider-api, driver-api, admin-api, rider-app, driver-app)
#
# في dev: اتركها فارغة → Sentry يُتجاهل بصمت
# في prod: ضع DSN حقيقي لكل خدمة

# Backend DSNs
SENTRY_DSN_RIDER_API=
SENTRY_DSN_DRIVER_API=
SENTRY_DSN_ADMIN_API=

# Generic SENTRY_DSN (fallback لو لم تضع DSN منفصل)
SENTRY_DSN=

# Flutter DSNs (تُمرَّر عبر --dart-define عند build)
# مثال: flutter build apk --dart-define=SENTRY_DSN=https://...
SENTRY_DSN_RIDER_APP=
SENTRY_DSN_DRIVER_APP=

# Release tag — في الإنتاج: استخدم git SHA (مثال: a1b2c3d4)
SENTRY_RELEASE=dev

# ===== CORS Hardening (production فقط) =====
#
# مهم: في الإنتاج لا تستخدم "*" مطلقاً. حدِّد كل origin بالضبط.
#
# تطبيقات Flutter لا تحتاج CORS (تستهلك GraphQL مباشرة من mobile binary)،
# لكنها تحتاج فقط في حالة دعم Web build لاحقاً.
#
# لذا: CORS_ORIGINS يخدم بشكل رئيسي:
#  - GraphQL Playground (dev tool — أزله في prod)
#  - أي web client مستقبلي للراكب/السائق
#  - dashboards خارجية
#
# تنسيق: قائمة origins مفصولة بفواصل، بدون trailing slash.
# مثال للإنتاج:
#   CORS_ORIGINS=https://rider.hancr.app,https://driver.hancr.app,https://app.hancr.app
#   ADMIN_CORS_ORIGINS=https://admin.hancr.app
#
# لـ Staging:
#   CORS_ORIGINS=https://staging-rider.hancr.app,https://staging-driver.hancr.app
#   ADMIN_CORS_ORIGINS=https://staging-admin.hancr.app
#
# في dev (NODE_ENV=development): يُتجاهَل هذا المتغير و CORS مفتوح.
CORS_ORIGINS=
ADMIN_CORS_ORIGINS=

# ===== Throttling Override (optional) =====
# الافتراضي: 100 طلب/60 ثانية للـ default، 10/60 للـ strict
THROTTLE_DEFAULT_LIMIT=100
THROTTLE_STRICT_LIMIT=10
THROTTLE_TTL_SECONDS=60

# ===== الأمنوار (S3) =====
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=me-south-1
S3_BUCKET=media.hancr.app

# ===== المنافذ =====
NODE_ENV=development
RIDER_API_PORT=3000
DRIVER_API_PORT=3001
ADMIN_API_PORT=3002

# ===== الإدارة =====
ADMIN_DEFAULT_EMAIL=admin@hancr.com
ADMIN_DEFAULT_PASSWORD=change_me_in_production

# ===== الموقع الافتراضي (الدوحة) =====
DEFAULT_LAT=25.2854
DEFAULT_LNG=51.5310
DEFAULT_REGION=QA
DEFAULT_CURRENCY=QAR
