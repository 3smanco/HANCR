{
  "name": "hancr",
  "version": "1.0.0-alpha.1",
  "description": "HANCR — Next-Gen Smart Mobility Platform for MENA | Zancr, LLC",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "rider-api": "nx serve rider-api",
    "rider-api:dev": "cross-env TS_NODE_PROJECT=apps/rider-api/tsconfig.app.json node --require tsconfig-paths/register --require ts-node/register/transpile-only apps/rider-api/src/main.ts",
    "driver-api": "nx serve driver-api",
    "driver-api:dev": "cross-env TS_NODE_PROJECT=apps/driver-api/tsconfig.app.json node --require tsconfig-paths/register --require ts-node/register/transpile-only apps/driver-api/src/main.ts",
    "admin-api": "nx serve admin-api",
    "admin-api:dev": "cross-env TS_NODE_PROJECT=apps/admin-api/tsconfig.app.json node --require tsconfig-paths/register --require ts-node/register/transpile-only apps/admin-api/src/main.ts",
    "build:rider-api": "nx build rider-api",
    "build:driver-api": "nx build driver-api",
    "build:admin-api": "nx build admin-api",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "migration:run": "typeorm migration:run -d libs/database/src/lib/data-source.ts",
    "migration:revert": "typeorm migration:revert -d libs/database/src/lib/data-source.ts",
    "migration:generate": "typeorm migration:generate -d libs/database/src/lib/data-source.ts",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1"
  },
