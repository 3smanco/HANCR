# =============================================
# HANCR — Production Environment Variables
# انسخ إلى .env.prod (لا تَرفعه إلى Git!)
# =============================================

# ===== Environment =====
NODE_ENV=production

# ===== Database (managed Postgres مُفضَّل — مثال: AWS RDS/Aiven) =====
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=hancr_prod
DATABASE_USER=hancr_prod
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ===== JWT — 3 أسرار منفصلة (64+ حرف عشوائي، لا تكرار) =====
# openssl rand -base64 48 لكل واحد. الخوادم ترفض الإقلاع إن نقص أيّ سرّ أو ضعُف.
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48
JWT_DRIVER_SECRET=CHANGE_ME_DIFFERENT_FROM_RIDER_AND_ADMIN
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_FROM_USER_JWT

# ===== المنافذ الداخلية (داخل Docker network) =====
RIDER_API_PORT=3000
DRIVER_API_PORT=3000
ADMIN_API_PORT=3000

# ═════════════════════════════════════════════════════════════════
# CORS — قائمة الـ origins المسموح بها لـ hancr.com
# ═════════════════════════════════════════════════════════════════
CORS_ORIGINS=https://hancr.com,https://www.hancr.com,https://rider.hancr.com,https://driver.hancr.com
ADMIN_CORS_ORIGINS=https://admin.hancr.com

# ═════════════════════════════════════════════════════════════════
# Public URLs (للـ webhooks + deep links + emails)
# ═════════════════════════════════════════════════════════════════
PUBLIC_BASE_URL=https://hancr.com
PUBLIC_API_URL=https://api.hancr.com
PUBLIC_ADMIN_URL=https://admin.hancr.com

# Webhook URL لبوابات الدفع (تُضيفه في HyperPay/Moyasar dashboard)
PAYMENT_WEBHOOK_URL=https://api.hancr.com/rider/wallet/webhook

# ===== الخرائط =====
GOOGLE_MAPS_API_KEY=YOUR_PRODUCTION_GOOGLE_MAPS_KEY
MAPBOX_TOKEN=YOUR_PRODUCTION_MAPBOX_TOKEN

# ===== Firebase (Push Notifications) =====
FIREBASE_PROJECT_ID=hancr-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@hancr-prod.iam.gserviceaccount.com

# ===== SMS (Twilio) =====
TWILIO_ACCOUNT_SID=YOUR_TWILIO_PROD_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_PROD_TOKEN
TWILIO_FROM_NUMBER=+9665XXXXXXXX

# ═══════════════════════════════════════════════════════════════
# بوابات الدفع — Production
# ═══════════════════════════════════════════════════════════════

# ─── HyperPay (الخليج) ───
# Get from: https://wordpresshyperpay.docs.oppwa.com/
HYPERPAY_ACCESS_TOKEN=YOUR_HYPERPAY_PROD_TOKEN
HYPERPAY_ENTITY_ID=YOUR_HYPERPAY_ENTITY_ID
HYPERPAY_BASE_URL=https://eu-prod.oppwa.com
HYPERPAY_WEBHOOK_SECRET=YOUR_HYPERPAY_WEBHOOK_HMAC_SECRET

# ─── Moyasar (السعودية) ───
# Get from: https://dashboard.moyasar.com/
MOYASAR_API_KEY=sk_live_YOUR_MOYASAR_KEY
MOYASAR_WEBHOOK_SECRET=YOUR_MOYASAR_WEBHOOK_HMAC_SECRET

# ─── Stripe (international + Apple Pay + Google Pay) ───
# Get from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
# Publishable key (للـ Flutter app — يُمرَّر عبر --dart-define)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# ═════════════════════════════════════════════════════════════════
# Sentry (المراقبة) — DSNs حقيقية من sentry.io
# ═════════════════════════════════════════════════════════════════
SENTRY_DSN_RIDER_API=https://YOUR_KEY@oXXX.ingest.sentry.io/YYY
SENTRY_DSN_DRIVER_API=https://YOUR_KEY@oXXX.ingest.sentry.io/ZZZ
SENTRY_DSN_ADMIN_API=https://YOUR_KEY@oXXX.ingest.sentry.io/WWW
SENTRY_RELEASE=v1.0.0  # update with git tag/SHA on each deploy

# ===== الأمنوار (AWS S3 لـ صور وملفات) =====
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
AWS_REGION=me-south-1
S3_BUCKET=media.hancr.com

# ===== الإدارة =====
ADMIN_DEFAULT_EMAIL=admin@hancr.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_INITIAL_PASSWORD

# ===== الموقع الافتراضي =====
DEFAULT_LAT=24.7136
DEFAULT_LNG=46.6753
DEFAULT_REGION=SA
DEFAULT_CURRENCY=SAR

# ===== Admin Panel =====
ADMIN_API_URL=https://api.hancr.com/admin/graphql
NEXT_PUBLIC_ADMIN_API_URL=https://api.hancr.com/admin/graphql
